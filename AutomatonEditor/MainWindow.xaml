<Window x:Class="DfaSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:DfaSimulator.Core"
        Title="Symulator i Edytor DFA" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <core:OffsetConverter x:Key="OffsetConverter" />
        <Polyline x:Key="ArrowHead" Points="0,0 10,5 0,10" Stroke="Black" Fill="Black"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>


    <Grid Background="#F5F6FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#DCDDE1" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15">
                    <TextBlock Text="EDYTOR AUTOMATÓW" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding Alphabet, StringFormat='Alfabet Σ: \{ {0} \}'}" 
                               FontWeight="Bold" Foreground="#2f3640" Margin="0,5,0,10" TextWrapping="Wrap"/>

                    <GroupBox Header="Właściwości wybranego stanu" Margin="0,0,0,15" Padding="10">
                        <StackPanel IsEnabled="{Binding IsStateSelected}">
                            <TextBlock Text="{Binding SelectedState.Name, StringFormat='Wybrany stan: {0}'}" FontWeight="Bold" Margin="0,0,0,10"/>
                            <CheckBox Content="Oznacz jako początkowy" IsChecked="{Binding SelectedState.IsInitial, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
                            <CheckBox Content="Oznacz jako akceptujący" IsChecked="{Binding SelectedState.IsAccepting, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                            <TextBlock Text="Promień stanu:"/>
                            <Slider Minimum="15" Maximum="50" Value="{Binding SelectedState.Radius, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>

                            <TextBlock Text="Kolor wypełnienia:"/>
                            <ComboBox SelectedValue="{Binding SelectedState.FillColor, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag" Margin="0,0,0,5">
                                <ComboBoxItem Tag="White">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="White" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Biały" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="LightGray">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="LightGray" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Jasnoszary" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="LightBlue">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="LightBlue" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Jasnoniebieski" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="LightGreen">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="LightGreen" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Jasnozielony" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="Yellow">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="Yellow" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Żółty" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="Orange">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="Orange" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Pomarańczowy" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="Pink">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="Pink" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Różowy" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="Plum">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="Plum" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Śliwkowy" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="PaleGoldenrod">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="PaleGoldenrod" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Złotawy" />
                                    </StackPanel>
                                </ComboBoxItem>
                            </ComboBox>

                            <TextBlock Text="Kolor krawędzi:"/>
                            <ComboBox SelectedValue="{Binding SelectedState.StrokeColor, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag" Margin="0,0,0,5">
                                <ComboBoxItem Tag="Black">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="Black" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Czarny" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="DarkGray">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="DarkGray" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Ciemnoszary" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="#E84118">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="#E84118" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Czerwony (Akcent)" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="Blue">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="Blue" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Niebieski" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="Green">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="Green" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Ciemnozielony" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="Purple">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="Purple" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Fioletowy" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="Brown">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="Brown" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Brązowy" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="Navy">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="Navy" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Granatowy" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="Teal">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="16" Height="16" Fill="Teal" Stroke="Black" Margin="0,0,5,0"/>
                                        <TextBlock Text="Morski" />
                                    </StackPanel>
                                </ComboBoxItem>
                            </ComboBox>
                            <TextBlock Text="Grubość krawędzi:"/>
                            <Slider Minimum="1" Maximum="10" Value="{Binding SelectedState.StrokeThickness, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                            <Button Content="Usuń stan" Command="{Binding DeleteStateCommand}" Background="#E84118" Foreground="White" Padding="5"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Dodaj przejście" Margin="0,0,0,15" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Z (Stan początkowy):"/>
                            <ComboBox ItemsSource="{Binding States}" SelectedItem="{Binding NewTransitionFrom}" DisplayMemberPath="Name" Margin="0,0,0,5"/>
                            <TextBlock Text="Do (Stan końcowy):"/>
                            <ComboBox ItemsSource="{Binding States}" SelectedItem="{Binding NewTransitionTo}" DisplayMemberPath="Name" Margin="0,0,0,5"/>
                            <TextBlock Text="Symbol (np. 0 или 1):"/>
                            <TextBox Text="{Binding NewTransitionSymbol, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                            <Button Content="Dodaj przejście" Command="{Binding AddTransitionCommand}" Padding="5" Background="#4CD137" Foreground="White"/>
                        </StackPanel>
                    </GroupBox>

                    <Button Content="Usuń wybrane przejście" 
                            Command="{Binding DeleteTransitionCommand}" 
                            Background="#E84118" Foreground="White" Margin="0,0,0,15" Padding="5"/>
                    <TextBlock Text="ZARZĄDZANIE" FontWeight="Bold" FontSize="14" Margin="0,10,0,5"/>
                    <Button Content="Zapisz do JSON" Command="{Binding SaveCommand}" Margin="0,0,0,5" Padding="5"/>
                    <Button Content="Wczytaj z JSON" Command="{Binding LoadCommand}" Margin="0,0,0,15" Padding="5"/>
                    <Button Content="Eksportuj jako obraz" Click="ExportButton_Click" Margin="0,0,0,15" Padding="5" Background="#9B59B6" Foreground="White" FontWeight="Bold"/>

                    <GroupBox Header="Symulacja i Historia" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Słowo wejściowe:"/>
                            <TextBox Text="{Binding InputWord, UpdateSourceTrigger=PropertyChanged}" 
         Margin="0,0,0,5" Padding="5" 
         IsEnabled="{Binding CanEditInput}"/>
                            <ItemsControl ItemsSource="{Binding InputWordCharacters}" Margin="0,0,0,10">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="20" Height="25" Margin="1" BorderThickness="1" BorderBrush="#DCDDE1" CornerRadius="2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                            <Setter Property="Background" Value="Yellow"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Character}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <Button Content="Start" Command="{Binding StartAnimationCommand}" Width="60" Margin="0,0,5,0" Background="#4CD137" Foreground="White" FontWeight="Bold"/>
                                <Button Content="Stop" Command="{Binding StopAnimationCommand}" Width="60" Margin="0,0,5,0" Background="#E84118" Foreground="White" FontWeight="Bold"/>
                                <Button Content="Reset" Command="{Binding ResetSimulationCommand}" Width="60" Background="#7F8FA6" Foreground="White" FontWeight="Bold"/>
                            </StackPanel>

                            <TextBlock Text="Szybkość animacji:" FontSize="11" Margin="0,0,0,2"/>
                            <Slider Minimum="200" Maximum="2000" Value="{Binding AnimationSpeed, UpdateSourceTrigger=PropertyChanged}" IsDirectionReversed="True" Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="WSTECZ" Command="{Binding SimulatePreviousStepCommand}" Width="70" Margin="0,0,5,0"/>
                                <Button Content="KROK" Command="{Binding SimulateStepCommand}" Width="70" Background="#0097E6" Foreground="White" FontWeight="Bold"/>
                            </StackPanel>

                            <TextBlock Text="{Binding SimulationStatus}" TextWrapping="Wrap" Margin="0,10,0,5" FontSize="11" FontWeight="SemiBold" Foreground="#2F3640"/>

                            <TextBlock Text="Historia kroków:" FontSize="10" FontWeight="Bold" Margin="0,5,0,2" Foreground="#7F8FA6"/>
                            <Border BorderBrush="#DCDDE1" BorderThickness="1" CornerRadius="3">
                                <ListBox x:Name="SimulationHistoryList" 
                     ItemsSource="{Binding SimulationHistorySteps}" 
                     Height="120" 
                     Background="#F1F2F6"
                     FontSize="11"
                     BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="2">
                                                <TextBlock Text="▶ " Foreground="#0097E6" FontSize="9" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid x:Name="VisualEditor" Grid.Column="1" ClipToBounds="True" Background="White"
      MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
      MouseMove="Canvas_MouseMove"
      MouseLeftButtonUp="Canvas_MouseLeftButtonUp">
            <ItemsControl ItemsSource="{Binding Transitions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Canvas>
                            <Canvas Visibility="{Binding IsNotSelfLoop, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Path Cursor="Hand" MouseLeftButtonDown="Transition_MouseLeftButtonDown">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="{Binding StartPoint}">
                                                <QuadraticBezierSegment Point1="{Binding ControlPoint}" Point2="{Binding EndPoint}" />
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Stroke" Value="Black"/>
                                            <Setter Property="StrokeThickness" Value="2"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Stroke" Value="#E84118"/>
                                                    <Setter Property="StrokeThickness" Value="4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <Polygon Points="-10,-5 0,0 -10,5" Fill="Black">
                                    <Polygon.RenderTransform>
                                        <TransformGroup>
                                            <RotateTransform Angle="{Binding Angle}"/>
                                            <TranslateTransform X="{Binding MidX}" Y="{Binding MidY}"/>
                                        </TransformGroup>
                                    </Polygon.RenderTransform>
                                </Polygon>
                            </Canvas>

                            <Canvas Visibility="{Binding IsSelfLoop, Converter={StaticResource BooleanToVisibilityConverter}}">

                                <Path Cursor="Hand" MouseLeftButtonDown="Transition_MouseLeftButtonDown">
                                    <Path.Data>
                                        <PathGeometry>
                                            <PathFigure StartPoint="{Binding From.CenterX, ConverterParameter=-15, Converter={StaticResource OffsetConverter}}">
                                                <ArcSegment Point="{Binding From.CenterX, ConverterParameter=15, Converter={StaticResource OffsetConverter}}" 
                                Size="30,35" RotationAngle="0" IsLargeArc="True" SweepDirection="Clockwise" />
                                            </PathFigure>
                                        </PathGeometry>
                                    </Path.Data>
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Stroke" Value="Black"/>
                                            <Setter Property="StrokeThickness" Value="2"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Stroke" Value="#E84118"/>
                                                    <Setter Property="StrokeThickness" Value="4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>

                                <Polygon Points="-6,-4 0,0 -6,4">
                                    <Polygon.Style>
                                        <Style TargetType="Polygon">
                                            <Setter Property="Fill" Value="Black"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Fill" Value="#E84118"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Polygon.Style>
                                    <Polygon.RenderTransform>
                                        <TransformGroup>
                                            <RotateTransform Angle="110"/>
                                            <TranslateTransform X="{Binding From.CenterX, ConverterParameter=12, Converter={StaticResource OffsetConverter}}" 
                                    Y="{Binding From.Y, ConverterParameter=2, Converter={StaticResource OffsetConverter}}"/>
                                        </TransformGroup>
                                    </Polygon.RenderTransform>
                                </Polygon>

                            </Canvas>

                            <Border Canvas.Left="{Binding MidX}" Canvas.Top="{Binding MidY}" Background="White" BorderBrush="Black" BorderThickness="1" CornerRadius="3" Padding="2" MouseLeftButtonDown="Transition_MouseLeftButtonDown">
                                <TextBlock Text="{Binding Symbol}" FontWeight="Bold" Foreground="Blue"/>
                            </Border>
                        </Canvas>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl ItemsSource="{Binding States}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Canvas Width="{Binding Diameter}" Height="{Binding Diameter}">
                            <Grid Width="{Binding Diameter}" Height="{Binding Diameter}" Cursor="Hand" Background="Transparent">
                                <Ellipse x:Name="StateCircle" Fill="{Binding FillColor}" Stroke="{Binding StrokeColor}" 
                                         StrokeThickness="{Binding StrokeThickness}" Width="{Binding Diameter}" Height="{Binding Diameter}"/>
                                <Ellipse x:Name="AcceptingCircle" Stroke="{Binding StrokeColor}" StrokeThickness="1" Margin="4" Visibility="Collapsed"/>
                                <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Grid>
                            <Path x:Name="InitialArrow" Fill="Black" Data="M -20,10 L 0,0 L 0,20 Z" Visibility="Collapsed" Canvas.Left="-20" Canvas.Top="{Binding Radius}">
                                <Path.RenderTransform>
                                    <TranslateTransform Y="-10"/>
                                </Path.RenderTransform>
                            </Path>
                        </Canvas>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsAccepting}" Value="True">
                                <Setter TargetName="AcceptingCircle" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsInitial}" Value="True">
                                <Setter TargetName="InitialArrow" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter TargetName="StateCircle" Property="Stroke" Value="#E84118" />
                                <Setter TargetName="StateCircle" Property="StrokeThickness" Value="4" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsCurrentSimulationState}" Value="True">
                                <Setter TargetName="StateCircle" Property="Fill" Value="Yellow" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</Window>